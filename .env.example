# Fine-grained PAT or classic PAT with public_repo/read:user access.
# For public data only, a classic token with no extra scopes is enough.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Optional token rotation. The server randomly selects an available token.
# GITHUB_TOKEN_2=github_pat_xxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN_3=github_pat_xxxxxxxxxxxxxxxxxxxx

# Optional public site URL used in metadata and generated examples.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/YOUR_USERNAME/alive-github-signals

# Optional: 300–86400 seconds. The route query param can override this.
DEFAULT_CACHE_SECONDS=300

# User-backed endpoints fail explicitly when this token is missing.
